# ═══════════════════════════════════════════════════════════════════════════════
#  Cabonnet React — Template de variáveis de ambiente
#  Copie para .env e preencha com seus valores reais.
#  NUNCA faça commit do .env — ele contém credenciais.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Grafana Gerencial (fonte de dados de OS) ─────────────────────────────────
GRAFANA_URL=https://seu-grafana.exemplo.com:3000
GRAFANA_USER=usuario@empresa.com.br
GRAFANA_PASS=sua_senha_grafana
GRAFANA_DS_UID=uid-do-datasource-postgresql

# ── Grafana Monitoramento (Juniper/PPPoE) ────────────────────────────────────
MONITOR_URL=https://monitoramento.exemplo.com
MONITOR_USER=usuario_monitoramento
MONITOR_PASS=sua_senha_monitor
MONITOR_DS_UID=uid-do-datasource-monitoramento

# ── Zabbix (plugin alexanderzobnin-zabbix-datasource) ────────────────────────
# UID encontrado em: Grafana → Configuration → Data Sources → Zabbix → URL
# Se vazio, usa MONITOR_DS_UID como fallback (pode causar erro 400)
ZABBIX_DS_UID=uid-do-datasource-zabbix

# ── iManager BI (detalhes de OS via API REST) ─────────────────────────────────
IMANAGER_URL=https://imanager.exemplo.com
IMANAGER_USER=usuario@empresa.com.br
IMANAGER_PASS=sua_senha_imanager

# ── Autenticação do Dashboard ────────────────────────────────────────────────
# Para acesso sem autenticação (desenvolvimento local), deixe LOGIN_PASS vazio.
LOGIN_USER=gestao
LOGIN_PASS=senha_segura

# Papéis adicionais (opcional — se o servidor suportar multi-usuário)
# LOGIN_GESTOR_USER=gestor     LOGIN_GESTOR_PASS=senha_gestor
# LOGIN_OPERADOR_USER=operador LOGIN_OPERADOR_PASS=senha_operador
# LOGIN_VIEWER_USER=viewer     LOGIN_VIEWER_PASS=senha_viewer

# ── Telegram — Bot e Grupos ──────────────────────────────────────────────────
# Crie o bot em @BotFather e adicione-o como membro de cada grupo.
TELEGRAM_BOT_TOKEN=0000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# IDs de supergrupo no formato -100XXXXXXXXXX
# Obtenha via: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_PRODUTIVIDADE=-100XXXXXXXXXX
TELEGRAM_CHAT_INSTACABLE=-100XXXXXXXXXX
TELEGRAM_CHAT_WES=-100XXXXXXXXXX
TELEGRAM_CHAT_ALERTAS=-100XXXXXXXXXX
TELEGRAM_CHAT_OPERACIONAL_THM=-100XXXXXXXXXX
# TELEGRAM_CHAT_REDE=-100XXXXXXXXXX   ← descomentar quando o grupo for criado

# Grupo padrão para mensagens automáticas globais (geralmente = PRODUTIVIDADE)
TELEGRAM_CHAT_ID=-100XXXXXXXXXX

# ── Claude AI — Narrativa Operacional Inteligente ────────────────────────────
# Obtenha em: https://console.anthropic.com/
# Se vazio, a análise por IA é desabilitada silenciosamente.
ANTHROPIC_API_KEY=sk-ant-...

# ── Vite — URL da API (dev standalone sem servidor.js) ───────────────────────
# Deixe vazio para same-origin (padrão em dev e prod via servidor.js).
# Preencha apenas se rodar o frontend standalone apontando para outro servidor.
VITE_API_URL=
